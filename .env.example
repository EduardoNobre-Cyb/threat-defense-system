# Core app config
DATABASE_URL=postgresql+psycopg2://threat_user:threat_password@localhost:5432/threat_modeling
JWT_SECRET_KEY=change-this-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword

# Optional CVE enrichment
VULNERS_API_KEY=

# Optional notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Optional email notifications (Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Optional fallback recipients
DEMO_RECIPIENT=admin@threatdefense.local
DEFAULT_ESCALATION_EMAIL=admin@threatdefense.local
